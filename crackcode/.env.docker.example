# Copy this file to .env and update the values before running docker compose

# Host port mappings
SERVER_PORT=5051
SERVER_INTERNAL_PORT=5051
CLIENT_PORT=4173

# Backend service configuration
NODE_ENV=production
PORT=5051
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/crackcode
JWT_SECRET=replace-with-secure-string
JWT_REFRESH_SECRET=replace-with-refresh-secret
CLIENT_URL=http://localhost:4173
CLIENT_URLS=http://localhost:4173
ENABLE_SESSION_CACHE=true

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SENDER_EMAIL=your-email@gmail.com

# External services
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
JUDGE0_API_KEY=your-judge0-api-key-here
OPENAI_API_KEY=your-openai-key-if-used
GOOGLE_GENAI_API_KEY=your-google-genai-key-if-used
GEMINI_API_KEY=your-gemini-api-key-here

# AI feature toggles
ENABLE_AI_AGENT=false
ENABLE_AI_ERROR_DIAGNOSIS=false
ENABLE_AI_ASSISTANT=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend build configuration
VITE_API_URL=http://localhost:5051
VITE_BACKEND_URL=http://localhost:5051
